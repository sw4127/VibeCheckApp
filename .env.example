# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# Anthropic API key — used server-side only for narration. Paste your own key.
ANTHROPIC_API_KEY=

# Pinned model snapshot for the free reading. Default Sonnet: the free reading is
# top-of-funnel marketing, quality drives shares, and total cost is bounded by the
# finite answer space + caching. Drop to claude-haiku-4-5 only if cost ever spikes.
ANTHROPIC_MODEL_NARRATION=claude-sonnet-4-6

# Public base URL used on the share card / OG image (no trailing slash).
# Local dev default; set to the deployed URL in production.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
