# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# Anthropic API key — used server-side only for narration. Paste your own key.
ANTHROPIC_API_KEY=

# Free/WC reading model. Recalibration: free tier = Haiku + aggressive caching
# (finite verdict space → ~$0). The stronger model is reserved for the paid report.
ANTHROPIC_MODEL_NARRATION=claude-haiku-4-5

# Paid premium-report model (covered by the sale). Sonnet; test Opus for max quality.
ANTHROPIC_MODEL_PREMIUM=claude-sonnet-4-6

# Stripe SECRET key (server-only). Use a TEST key (sk_test_...) until launch.
# With this empty, /api/checkout returns 501 and the paywall offers a dev unlock
# in non-production so the gated report is still testable.
STRIPE_SECRET_KEY=

# Public base URL used on share/OG image + Stripe success/cancel URLs (no trailing slash).
NEXT_PUBLIC_BASE_URL=http://localhost:3000
