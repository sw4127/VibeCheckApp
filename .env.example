# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# Anthropic API key — used server-side only for narration. Paste your own key.
ANTHROPIC_API_KEY=

# Free/WC reading model. Recalibration: free tier = Haiku + aggressive caching
# (finite verdict space → ~$0). The stronger model is reserved for the paid report.
ANTHROPIC_MODEL_NARRATION=claude-haiku-4-5

# Paid premium-report model (covered by the sale). Sonnet; test Opus for max quality.
ANTHROPIC_MODEL_PREMIUM=claude-sonnet-4-6

# Payments — Merchant of Record (spec §24). With the provider unconfigured,
# /api/checkout returns 501 and the paywall offers a dev unlock in non-production
# so the gated report stays testable.
PAYMENTS_PROVIDER=dodo
# Dodo Payments — server-only API key. Use a TEST key first.
DODO_API_KEY=
# Dodo product id for "Vibe Check — The Full Read" ($3.99), created in the dashboard.
DODO_PRODUCT_ID=
# "test" (default) or "live" — selects the Dodo API base URL.
DODO_MODE=test

# Public base URL used on share/OG image + Stripe success/cancel URLs (no trailing slash).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Support/contact email shown on /legal (optional — without it, copy points
# users at their Stripe receipt, which also reaches you).
NEXT_PUBLIC_SUPPORT_EMAIL=
